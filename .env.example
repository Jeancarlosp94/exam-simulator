# ───────────────────────────────────────────────────────────────────────────
# Quizen — Variables de entorno
# Copia este archivo a .env.local y completa los valores reales.
# .env.local está ignorado por git. NUNCA commitees claves reales.
# ───────────────────────────────────────────────────────────────────────────

# ─── AI provider selection ───────────────────────────────────────────────
# Quizen soporta dos proveedores para generación de quizzes:
#   gemini    — Google Gemini, tier free generoso (1M tokens/día). Default.
#   anthropic — Claude Opus 4.7, pago pero mayor calidad.
# Cambia este valor para switchear sin tocar código.
AI_PROVIDER=gemini

# ─── Gemini (default — gratis) ───────────────────────────────────────────
# Free tier: 1M tokens/día input, 15 RPM. Más que suficiente para dev.
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Anthropic (opcional — solo si AI_PROVIDER=anthropic) ────────────────
# No tiene tier free; ~$5 de crédito al crear cuenta.
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-opus-4-7

# ─── Supabase (Postgres + Auth + Storage) ────────────────────────────────
# Crear proyecto en: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role (server-only, nunca expuesta al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe (suscripción) ────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────
# Crear en: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── App config ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Quizen

# ─── Cron (Sprint 13 — daily reminders) ──────────────────────────────────
# Vercel Cron auto-sends Authorization: Bearer <CRON_SECRET> when this is
# set in Vercel env vars. /api/cron/daily-reminders verifies it. Without
# this set, the route runs unauthenticated (fine for local dev).
CRON_SECRET=

# ─── Web Push (Sprint 13b — notificaciones nativas en el navegador) ──────
# Genera VAPID keys una sola vez con:
#   npx web-push generate-vapid-keys
# Te imprime Public + Private. Pegalas acá y en Vercel env vars.
# La pública es safe-to-expose (NEXT_PUBLIC_*). La privada NUNCA al cliente.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contacto que VAPID firma en cada push (mailto:tuemail@ejemplo.com)
VAPID_CONTACT_EMAIL=mailto:tu-email@ejemplo.com

# ─── Google OAuth (login provider) ───────────────────────────────────────
# Quizen usa Google OAuth como único método de login. No necesitás keys
# acá — Supabase guarda el Client ID y Secret en su dashboard.
#
# Setup:
#   1. Google Cloud Console → APIs & Services → Credentials
#   2. "Create OAuth client ID" → Web application
#   3. Authorized redirect URI:
#      https://<tu-proyecto>.supabase.co/auth/v1/callback
#   4. Copiar Client ID + Client Secret
#   5. Supabase Dashboard → Authentication → Providers → Google →
#      pegar ambos → Enable

# ─── Observabilidad (opcional en local) ──────────────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
