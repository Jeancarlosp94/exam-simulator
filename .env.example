# ───────────────────────────────────────────────────────────────────────────
# Quizen — Variables de entorno
# Copia este archivo a .env.local y completa los valores reales.
# .env.local está ignorado por git. NUNCA commitees claves reales.
# ───────────────────────────────────────────────────────────────────────────

# ─── Anthropic (Claude API) ──────────────────────────────────────────────
# Modelo por defecto para generación de quizzes: claude-opus-4-7
# Crear en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-opus-4-7

# ─── Supabase (Postgres + Auth + Storage) ────────────────────────────────
# Crear proyecto en: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role (server-only, nunca expuesta al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe (suscripción) ────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────
# Crear en: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── Resend (emails transaccionales / magic links) ───────────────────────
# Crear en: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Quizen <noreply@quizen.app>

# ─── App config ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Quizen

# ─── Observabilidad (opcional en local) ──────────────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
