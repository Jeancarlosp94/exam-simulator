# ───────────────────────────────────────────────────────────────────────────
# Quizen — Variables de entorno
# Copia este archivo a .env.local y completa los valores reales.
# .env.local está ignorado por git. NUNCA commitees claves reales.
# ───────────────────────────────────────────────────────────────────────────

# ─── AI provider selection ───────────────────────────────────────────────
# Quizen soporta dos proveedores para generación de quizzes:
#   gemini    — Google Gemini, tier free generoso (1M tokens/día). Default.
#   anthropic — Claude Opus 4.7, pago pero mayor calidad.
# Cambia este valor para switchear sin tocar código.
AI_PROVIDER=gemini

# ─── Gemini (default — gratis) ───────────────────────────────────────────
# Free tier: 1M tokens/día input, 15 RPM. Más que suficiente para dev.
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Anthropic (opcional — solo si AI_PROVIDER=anthropic) ────────────────
# No tiene tier free; ~$5 de crédito al crear cuenta.
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-opus-4-7

# ─── Supabase (Postgres + Auth + Storage) ────────────────────────────────
# Crear proyecto en: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role (server-only, nunca expuesta al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe (suscripción) ────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────
# Crear en: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── Resend (emails transaccionales / magic links) ───────────────────────
# Crear en: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Quizen <noreply@quizen.app>

# ─── App config ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Quizen

# ─── Cloudflare Turnstile (opcional — captcha en /login) ─────────────────
# Sin esto, /login funciona sin captcha (OK para dev). En producción
# protege contra bots que crean cuentas masivas para gastar tu cuota
# Gemini.
#
# Setup:
#   1. Sign up en https://www.cloudflare.com (free)
#   2. Dashboard → Turnstile → "Add site" → mode: Managed
#   3. Hostnames: tu-dominio.vercel.app y localhost
#   4. Copia el "Site Key" → NEXT_PUBLIC_TURNSTILE_SITE_KEY abajo
#   5. Copia el "Secret Key" → pégalo en Supabase Dashboard →
#      Authentication → Settings → Bot and Abuse Protection → "Enable
#      Captcha protection" → provider: Cloudflare Turnstile → paste secret
# Supabase verifica el token server-side; no necesitas el secret en tu .env.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ─── Observabilidad (opcional en local) ──────────────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
